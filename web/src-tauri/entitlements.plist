<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    Hardened-runtime entitlements for the notarized Predikt app. The bundled
    Node runtime (V8) JITs machine code and dlopen's native addons, so it needs
    these three exceptions or it is killed the moment it runs under the hardened
    runtime that notarization requires:
      - allow-jit + allow-unsigned-executable-memory: V8's JIT writes+executes.
      - disable-library-validation: load libnode.dylib and the QVAC .bare native
        addons, which aren't part of the app's own team signature.
  -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
