# Web build config. Copy to `.env` (gitignored) for local overrides, or set these
# as environment variables in your host (e.g. Vercel → Settings → Environment Variables).

# Absolute backend base URL. Leave UNSET for same-origin — that's correct for local
# dev (Vite proxy) and for the single-service server that serves the SPA + API
# together (Railway / `npm run tunnel`).
#
# Set it ONLY when the frontend is hosted separately from the backend — e.g. a
# Vercel frontend (prediktt.xyz) talking to the Railway backend. No trailing slash.
# VITE_API_BASE=https://glistening-reverence-production-c01a.up.railway.app
