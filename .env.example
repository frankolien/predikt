# Copy to `.env` (which is gitignored) and fill in. Nothing here is required to
# run the local demo — these only enrich it.

# --- Live football feed (recommended) ---
# football-data.org free API key → true in-play World Cup 2026 status + scores,
# pushed to the UI in real time. Without it, the app uses the keyless TheSportsDB
# fallback (fixtures/results are real; live minute is best-effort).
# Get one free at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# --- Telegram companion bot (optional) ---
# TELEGRAM_BOT_TOKEN=

# --- Money layer (testnet only; local mode needs none of these) ---
# GAFFER_MODE=testnet
# GAFFER_RPC_URL=
# GAFFER_OPERATOR_KEY=
# GAFFER_USDT_ADDRESS=
