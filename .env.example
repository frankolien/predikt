# Copy to `.env` (which is gitignored) and fill in. Nothing here is required to
# run the local demo — these only enrich it.

# --- Live football feed (recommended) ---
# football-data.org free API key → true in-play World Cup 2026 status + scores,
# pushed to the UI in real time. Without it, the app uses the keyless TheSportsDB
# fallback (fixtures/results are real; live minute is best-effort).
# Get one free at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# --- Telegram companion bot (optional) ---
# TELEGRAM_BOT_TOKEN=

# --- Money layer (testnet only; local mode needs none of these) ---
# GAFFER_MODE=testnet
# GAFFER_RPC_URL=
# GAFFER_OPERATOR_KEY=
# GAFFER_USDT_ADDRESS=

# --- Wallet network switch (Solflare-style) ---
# The app BOOTS on one network (its pools/operator/faucet live there), but a fan's
# self-custodial wallet is the SAME address on every EVM chain — so the money card
# (balance / send / receive) can switch to another network at runtime. A network is
# only offered in the switcher if its USD₮ token is known.
#   • Arbitrum One (mainnet, "LIVE") is always offered — it uses the canonical USD₮
#     (0xFd086bC7CD5C481DCC9C85ebE478A1C0b69FCbb9). Override to point at USD₮0, etc:
# GAFFER_USDT_ADDRESS_ARBITRUM=0x...
#   • To also offer Arbitrum Sepolia as a switch target, set its test token:
# GAFFER_USDT_ADDRESS_ARBITRUM_SEPOLIA=0x...
#   • Per-network RPC overrides (else the public default RPC is used):
# GAFFER_RPC_URL_ARBITRUM=
# GAFFER_RPC_URL_ARBITRUM_SEPOLIA=

# --- Database (Postgres) ---
# Local dev defaults to postgres://gaffer:gaffer@127.0.0.1:5433/gaffer if unset.
# On Railway, the Postgres plugin injects DATABASE_URL for you.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# Set to `require` when connecting to a managed Postgres over the public internet
# (Railway's private-network URL does not need it):
# DATABASE_SSL=require

# --- Deploy / serving (container) ---
# PORT is injected by the platform; defaults to 8787 locally.
# HOST defaults to 0.0.0.0 (all interfaces) so the container is reachable.
# GAFFER_SERVE_WEB=1 forces the API to serve web/dist; auto-on when the build exists.
# GAFFER_MODE=local ships a bundled anvil chain (ephemeral demo USD₮).
# PORT=8787
# HOST=0.0.0.0
# GAFFER_SERVE_WEB=1
